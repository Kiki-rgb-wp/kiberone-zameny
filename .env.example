# Supabase (обязательно) — подставь свои значения из Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://ТВОЙ_PROJECT.supabase.co
SUPABASE_ANON_KEY=твой_anon_key
SUPABASE_SERVICE_ROLE_KEY=твой_service_role_key
# JWT для проверки токенов (тот же секрет, что в Supabase Dashboard)
JWT_SECRET=your-jwt-secret

# Email (SendGrid или Resend) — для уведомлений админам
SENDGRID_API_KEY=
RESEND_API_KEY=
NOTIFY_EMAIL_ADMIN=admin@kiberone.com

# Опционально: Slack/Telegram webhook для ботов
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Railway / порт
PORT=3000

# Фронт (для сборки Mini App): URL бэкенда без слэша в конце
# VITE_API_URL=https://your-api.up.railway.app
